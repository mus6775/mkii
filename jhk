
#include <iostream>
#include <vector>
using namespace std;

vector<string> tasks;


void addTask() {
    string task;
    cout << "Enter task: ";
    cin.ignore();
    getline(cin, task);
    tasks.push_back(task);
}

void showTasks() {
    cout << "\nYour Tasks:\n";
    for (int i = 0; i < tasks.size(); i++) {
        cout << i + 1 << ". " << tasks[i] << endl;
    }
}

void deleteTask() {
    int num;
    cout << "Enter task number to delete: ";
    cin >> num;
    if (num > 0 && num <= tasks.size()) {
        tasks.erase(tasks.begin() + num - 1);
    } else {
        cout << "Invalid number!\n";
    }
}

int main() {
    int choice;
    while (true) {
        cout << "\n1. Add Task\n2. Show Tasks\n3. Delete Task\n4. Exit\n";
        cout << "Choose: ";
        cin >> choice;

        switch (choice) {
            case 1: addTask(); break;
            case 2: showTasks(); break;
            case 3: deleteTask(); break;
            case 4: return 0;
            default: cout << "Invalid choice!\n";
        }
    }
}